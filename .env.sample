# Environment
NODE_ENV=development

# Server configuration
PORT=8080
HOST=0.0.0.0

# Database/Storage configuration
# PostgreSQL connection string (e.g., postgresql://user:pass@host:5432/dbname?sslmode=disable)
# Required for production, should be set via DATABASE_URL environment variable
DATABASE_URL=postgresql://username:password@localhost:5432/dbname?sslmode=disable

# Auth service configuration
AUTH_SERVICE_URL=http://localhost:8080
AUTH_SERVICE_SECRET=better-auth-secret-change-in-production

# CORS configuration (comma-separated)
ALLOWED_ORIGIN=http://localhost:3000,http://localhost:7443

# Cookie configuration (for production with custom domains)
# AUTH_COOKIE_DOMAIN=.example.com  # Base domain for cross-subdomain cookies (e.g., .nixopus.com)
# AUTH_SECURE_COOKIES=true # Enable Secure flag for cookies (required for HTTPS)

# Resend configuration
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=your_email@example.com

# Secret Manager Configuration (optional)
SECRET_MANAGER_ENABLED=false
SECRET_MANAGER_TYPE=infisical
SECRET_MANAGER_PROJECT_ID=
SECRET_MANAGER_ENVIRONMENT=prod
SECRET_MANAGER_SECRET_PATH=/
INFISICAL_URL=https://app.infisical.com
INFISICAL_TOKEN=

# Cloudflare Turnstile (CAPTCHA)
# Get keys at https://dash.cloudflare.com/turnstile
# For local dev, use test key: 1x0000000000000000000000000000000AA (always passes)
# Leave blank to disable captcha verification
TURNSTILE_SECRET_KEY=

# Dodo Payments Configuration
# Required for Dodo Payments integration
DODO_PAYMENTS_API_KEY=your_dodo_payments_api_key_here
DODO_PAYMENTS_WEBHOOK_SECRET=your_webhook_secret_here
DODO_PAYMENTS_ENVIRONMENT=test_mode
DODO_PAYMENTS_PRODUCT_ID=pdt.dodo_payments_product_id
DODO_PAYMENTS_PRODUCT_SLUG=dodo_payments_product_slug
