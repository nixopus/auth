SELF_HOSTED=true
NODE_ENV=production

PORT=9090
HOST=0.0.0.0

DATABASE_URL=postgresql://username:password@localhost:5432/nixopus_auth?sslmode=disable

AUTH_SERVICE_URL=https://auth.yourdomain.com
AUTH_SERVICE_SECRET=change-me-to-a-random-secret

ALLOWED_ORIGIN=https://yourdomain.com

# Admin user seeded on first startup (set by installer)
ADMIN_EMAIL=admin@yourdomain.com

# Resend configuration (optional - OTPs logged to console if not set)
# RESEND_API_KEY=your_resend_api_key_here
# RESEND_FROM_EMAIL=Nixopus <no-reply@yourdomain.com>

# Cookie configuration (required for HTTPS deployments with custom domains)
# AUTH_COOKIE_DOMAIN=.yourdomain.com
# AUTH_SECURE_COOKIES=true
